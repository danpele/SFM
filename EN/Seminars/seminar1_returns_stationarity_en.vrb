\frametitle{AI Exercise (II): Code Generation and Verification}
\begin{block}{Task}
\begin{itemize}
    \item Ask an LLM: \textit{``Write Python code that downloads AAPL data for 2020--2024, computes log returns, tests stationarity with the ADF test, and displays a price vs.\ returns chart.''}
    \item Run the generated code --- does it work \textit{as-is}?
\end{itemize}
\end{block}
\vspace{0.1cm}
\begin{alertblock}{Verification checklist}
\begin{itemize}
    \item Are the imports correct? (yfinance, numpy, statsmodels)
    \item Return formula: \texttt{np.log(P/P.shift(1))} or \texttt{pct\_change()}?
    \begin{itemize}
        \item Caution: \texttt{pct\_change()} $=$ \textbf{simple} returns, not log!
    \end{itemize}
    \item ADF test: correct interpretation of the $p$-value?
    \item Does the plot have titles, axis labels, legend?
\end{itemize}
\end{alertblock}
\vspace{0.1cm}
\begin{exampleblock}{Pedagogical objective}
\begin{itemize}
    \item AI is a \textbf{tool}, not a substitute --- generated code must \textbf{always be verified}
    \item Common error: confusion between simple and log returns
\end{itemize}
\end{exampleblock}
